+const vector<TransactionModificationCallback> *GetTxnModificationCallbacks(DatabaseInstance &db);
+//! Engine-internal: drop an instance's callbacks (called from ~DatabaseInstance).
+void UnregisterTxnModificationCallbacks(DatabaseInstance &db);
