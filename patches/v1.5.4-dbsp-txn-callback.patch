+//! DBSP engine hook payload: one committing transaction's net tuple
+//! modifications for a single table, full-width in physical column order
+//! (DataTable::GetTypes()). old_rows are pre-transaction images of deleted
+//! and updated rows (Z-weight -1); new_rows are post-transaction images of
+//! inserted and updated rows (Z-weight +1). A row both updated and deleted
+//! in the transaction appears once, in old_rows, with its pre-transaction
+//! image; a row inserted and deleted in the transaction appears nowhere.
+struct TransactionModifications {
+	vector<LogicalType> types;
+	unique_ptr<ColumnDataCollection> old_rows;
+	unique_ptr<ColumnDataCollection> new_rows;
+};
+
+//! DBSP engine hook: fired inside DuckTransaction::Commit (after the undo
+//! commit, before WAL flush) with the exact per-table modifications of the
+//! committing transaction. DataTableInfo carries the schema/table names.
+struct TransactionModificationCallback {
+	std::function<void(ClientContext &, DataTableInfo &, TransactionModifications &)> on_commit;
+};
+
+//! The registry lives in the DatabaseInstance-owned ObjectCache — state on
+//! the SHARED INSTANCE OBJECT, never per-image statics. A loadable extension
+//! contains its own statically-linked engine copy, so a static/global
+//! registry exists twice (extension registers into its image's copy, the
+//! host engine reads its own — the hook silently never fires; found by
+//! benchmark + `nm`: RegisterTxnModificationCallback is a LOCAL symbol in
+//! dbsp.duckdb_extension). ObjectCache also dies with the instance, so no
+//! recycled-address cleanup is needed. DBConfig stays untouched (ABI).
+class TxnModificationCallbackRegistry : public ObjectCacheEntry {
+public:
+	static constexpr const char *KEY = "dbsp_txn_modification_callbacks_v1";
+
+	std::mutex lock;
+	vector<TransactionModificationCallback> callbacks;
+
+	string GetObjectType() override {
+		return KEY;
+	}
+	static string ObjectType() {
+		return KEY;
+	}
+	optional_idx GetEstimatedCacheMemory() const override {
+		// invalid index = never evict: the hook registry must live exactly
+		// as long as the DatabaseInstance
+		return optional_idx();
+	}
+};
+
+//! Register a callback on this instance (creates the registry entry on first
+//! use). Callable from either image: all state hangs off `db`.
+void RegisterTxnModificationCallback(DatabaseInstance &db, TransactionModificationCallback callback);
+//! The instance's registry entry, or nullptr when nothing ever registered.
+shared_ptr<TxnModificationCallbackRegistry> GetTxnModificationCallbacks(DatabaseInstance &db);
