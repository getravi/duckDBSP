+
+void UndoBuffer::StreamModifications(const vector<TransactionModificationCallback> &cbs) {
+	// This is WriteToWAL()'s traversal with a different sink: instead of
+	// serializing operations, assemble full-width old/new row images per table
+	// and hand them to the registered callbacks.
+	auto context_ptr = transaction.context.lock();
+	if (!context_ptr) {
+		return;
+	}
+	auto &context = *context_ptr;
+
+	// Pass 1: collect per-table modified row ids from the undo entries.
+	struct TableMods {
+		vector<pair<idx_t, idx_t>> insert_ranges; // (start_row, count)
+		vector<row_t> deleted;
+		vector<row_t> updated;
+	};
+	map<DataTable *, TableMods> tables;
+	UndoBuffer::IteratorState iterator_state;
+	IterateEntries(iterator_state, [&](UndoFlags type, data_ptr_t data) {
+		switch (type) {
+		case UndoFlags::INSERT_TUPLE: {
+			auto info = reinterpret_cast<AppendInfo *>(data);
+			if (!info->table->IsTemporary()) {
+				tables[info->table].insert_ranges.emplace_back(info->start_row, info->count);
+			}
+			break;
+		}
+		case UndoFlags::DELETE_TUPLE: {
+			auto info = reinterpret_cast<DeleteInfo *>(data);
+			if (info->table->IsTemporary()) {
+				break;
+			}
+			auto &mods = tables[info->table];
+			if (info->is_consecutive) {
+				for (idx_t i = 0; i < info->count; i++) {
+					mods.deleted.push_back(UnsafeNumericCast<row_t>(info->base_row + i));
+				}
+			} else {
+				auto rows = info->GetRows();
+				for (idx_t i = 0; i < info->count; i++) {
+					mods.deleted.push_back(UnsafeNumericCast<row_t>(info->base_row) + rows[i]);
+				}
+			}
+			break;
+		}
+		case UndoFlags::UPDATE_TUPLE: {
+			auto info = reinterpret_cast<UpdateInfo *>(data);
+			if (info->table->IsTemporary()) {
+				break;
+			}
+			auto &mods = tables[info->table];
+			idx_t start = info->row_group_start + info->vector_index * STANDARD_VECTOR_SIZE;
+			auto tuples = info->GetTuples();
+			for (idx_t i = 0; i < info->N; i++) {
+				mods.updated.push_back(UnsafeNumericCast<row_t>(start + tuples[i]));
+			}
+			break;
+		}
+		default:
+			break;
+		}
+	});
+	if (tables.empty()) {
+		return;
+	}
+
+	auto &allocator = Allocator::Get(context);
+	for (auto &table_entry : tables) {
+		auto &table = *table_entry.first;
+		auto &mods = table_entry.second;
+
+		// Dedupe update row ids (one UpdateInfo per updated column per vector).
+		std::sort(mods.updated.begin(), mods.updated.end());
+		mods.updated.erase(std::unique(mods.updated.begin(), mods.updated.end()), mods.updated.end());
+		std::sort(mods.deleted.begin(), mods.deleted.end());
+		// Rows both updated and deleted net to the delete's pre-image alone —
+		// the transactional fetch below would happily return a pre-image for
+		// them too (the stamped delete is invisible to the committing reader),
+		// so they must be removed here, not left to fetch-time filtering.
+		// Rows updated inside this transaction's own insert ranges are covered
+		// by the insert-range committed fetch (final values) — drop those too.
+		vector<row_t> updated;
+		updated.reserve(mods.updated.size());
+		for (auto row_id : mods.updated) {
+			if (std::binary_search(mods.deleted.begin(), mods.deleted.end(), row_id)) {
+				continue;
+			}
+			bool in_own_insert = false;
+			for (auto &range : mods.insert_ranges) {
+				if (row_id >= UnsafeNumericCast<row_t>(range.first) &&
+				    row_id < UnsafeNumericCast<row_t>(range.first + range.second)) {
+					in_own_insert = true;
+					break;
+				}
+			}
+			if (!in_own_insert) {
+				updated.push_back(row_id);
+			}
+		}
+
+		TransactionModifications result;
+		result.types = table.GetTypes();
+		vector<StorageIndex> column_ids;
+		for (idx_t i = 0; i < result.types.size(); i++) {
+			column_ids.emplace_back(i);
+		}
+		result.old_rows = make_uniq<ColumnDataCollection>(allocator, result.types);
+		result.new_rows = make_uniq<ColumnDataCollection>(allocator, result.types);
+
+		// Old images: pre-transaction rows for deletes and updates.
+		FetchRowsInto(table, result.types, column_ids, mods.deleted, &transaction, allocator, *result.old_rows);
+		FetchRowsInto(table, result.types, column_ids, updated, &transaction, allocator, *result.old_rows);
+		// New images: post-transaction rows for updates and inserts.
+		FetchRowsInto(table, result.types, column_ids, updated, nullptr, allocator, *result.new_rows);
+		for (auto &range : mods.insert_ranges) {
+			vector<row_t> insert_rows;
+			insert_rows.reserve(range.second);
+			for (idx_t i = 0; i < range.second; i++) {
+				insert_rows.push_back(UnsafeNumericCast<row_t>(range.first + i));
+			}
+			FetchRowsInto(table, result.types, column_ids, insert_rows, nullptr, allocator, *result.new_rows);
+		}
+
+		if (result.old_rows->Count() == 0 && result.new_rows->Count() == 0) {
+			continue;
+		}
+		auto &table_info = *table.GetDataTableInfo();
+		for (auto &cb : cbs) {
+			if (cb.on_commit) {
+				cb.on_commit(context, table_info, result);
+			}
+		}
+	}
+}
 } // namespace duckdb
