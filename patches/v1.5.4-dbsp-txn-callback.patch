+// Batched full-width row fetch into a ColumnDataCollection. When `transaction`
+// is set, uses the committing transaction's own snapshot: because commit ids
+// are already stamped (StreamModifications runs after UndoBuffer::Commit),
+// this returns PRE-transaction images — stamped deletes look like a future
+// transaction's deletes (row still visible) and stamped update chains resolve
+// to the old versions. Rows the transaction inserted itself are invisible on
+// this path and get silently dropped, which is exactly right for old images.
+// When `transaction` is null, uses the committed reader (FetchCommitted):
+// post-transaction images — sees the stamped inserts and base (new) update
+// values, and drops rows the transaction itself deleted.
+void FetchRowsInto(DataTable &table, const vector<LogicalType> &types, const vector<StorageIndex> &column_ids,
+                   const vector<row_t> &row_ids, optional_ptr<DuckTransaction> transaction, Allocator &allocator,
+                   ColumnDataCollection &out) {
+	if (row_ids.empty()) {
+		return;
+	}
+	DataChunk chunk;
+	chunk.Initialize(allocator, types);
+	for (idx_t offset = 0; offset < row_ids.size(); offset += STANDARD_VECTOR_SIZE) {
+		idx_t count = MinValue<idx_t>(STANDARD_VECTOR_SIZE, row_ids.size() - offset);
+		Vector rid_vec(LogicalType::ROW_TYPE,
+		               data_ptr_cast(const_cast<row_t *>(row_ids.data() + offset))); // NOLINT: read-only view
+		ColumnFetchState fetch_state;
+		chunk.Reset();
+		if (transaction) {
+			table.Fetch(*transaction, chunk, column_ids, rid_vec, count, fetch_state);
+		} else {
+			table.FetchCommitted(chunk, column_ids, rid_vec, count, fetch_state);
+		}
+		if (chunk.size() > 0) {
+			out.Append(chunk);
+		}
+	}
+}
