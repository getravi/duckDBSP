+//===--------------------------------------------------------------------===//
+// DBSP engine hook: txn-modification callback registry
+//===--------------------------------------------------------------------===//
+// Side registry keyed by DatabaseInstance* — deliberately NOT a DBConfig
+// member (DBConfig is embedded in DatabaseInstance; growing it breaks the
+// ABI of prebuilt stock-header extensions). See undo_buffer.hpp.
+namespace {
+struct TxnModificationRegistry {
+	mutex lock;
+	unordered_map<DatabaseInstance *, vector<TransactionModificationCallback>> callbacks;
+
+	static TxnModificationRegistry &Get() {
+		static TxnModificationRegistry registry;
+		return registry;
+	}
+};
+} // namespace
+
+void RegisterTxnModificationCallback(DatabaseInstance &db, TransactionModificationCallback callback) {
+	auto &registry = TxnModificationRegistry::Get();
+	lock_guard<mutex> guard(registry.lock);
+	registry.callbacks[&db].push_back(std::move(callback));
+}
+
+const vector<TransactionModificationCallback> *GetTxnModificationCallbacks(DatabaseInstance &db) {
+	auto &registry = TxnModificationRegistry::Get();
+	lock_guard<mutex> guard(registry.lock);
+	auto entry = registry.callbacks.find(&db);
+	if (entry == registry.callbacks.end() || entry->second.empty()) {
+		return nullptr;
+	}
+	// Stable for the instance's lifetime: registration happens at extension
+	// load, the vector is only appended to, and erasure only runs in
+	// ~DatabaseInstance when no transaction can still be committing.
+	return &entry->second;
+}
+
+void UnregisterTxnModificationCallbacks(DatabaseInstance &db) {
+	auto &registry = TxnModificationRegistry::Get();
+	lock_guard<mutex> guard(registry.lock);
+	registry.callbacks.erase(&db);
+}
