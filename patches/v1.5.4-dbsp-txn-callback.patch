+//===--------------------------------------------------------------------===//
+// DBSP engine hook: txn-modification callback registry (ObjectCache-backed)
+//===--------------------------------------------------------------------===//
+// State hangs off the DatabaseInstance's ObjectCache so BOTH images of the
+// engine (host + a loadable extension's statically-linked copy) see one
+// registry. See the class comment in undo_buffer.hpp.
+
+void RegisterTxnModificationCallback(DatabaseInstance &db, TransactionModificationCallback callback) {
+	auto &cache = db.GetObjectCache();
+	auto existing = cache.GetObject(TxnModificationCallbackRegistry::KEY);
+	shared_ptr<TxnModificationCallbackRegistry> registry;
+	if (existing && existing->GetObjectType() == TxnModificationCallbackRegistry::ObjectType()) {
+		registry = shared_ptr_cast<ObjectCacheEntry, TxnModificationCallbackRegistry>(existing);
+	} else {
+		registry = make_shared_ptr<TxnModificationCallbackRegistry>();
+		cache.Put(TxnModificationCallbackRegistry::KEY, registry);
+	}
+	std::lock_guard<std::mutex> guard(registry->lock);
+	registry->callbacks.push_back(std::move(callback));
+}
+
+shared_ptr<TxnModificationCallbackRegistry> GetTxnModificationCallbacks(DatabaseInstance &db) {
+	auto existing = db.GetObjectCache().GetObject(TxnModificationCallbackRegistry::KEY);
+	if (!existing || existing->GetObjectType() != TxnModificationCallbackRegistry::ObjectType()) {
+		return nullptr;
+	}
+	return shared_ptr_cast<ObjectCacheEntry, TxnModificationCallbackRegistry>(existing);
+}
